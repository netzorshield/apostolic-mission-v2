# Copy to .env and fill in before running. Never commit .env.

# ── Application ──────────────────────────────────────────────
APP_ENV=development
# development | staging | production

# ── API ──────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8001
API_PREFIX=/api

# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=iam_database

# ── JWT (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))") ──
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Admin seed (REQUIRED on first boot — use a strong unique password) ──
ADMIN_EMAIL=admin@your-domain.org
ADMIN_PASSWORD=
ADMIN_NAME=IAM Administrator

# ── CORS (comma-separated origins — never use * in production) ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8001

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
# Set false only for local development with self-signed certs
REQUIRE_HTTPS=false

# ── Email (optional — or configure in Admin → Password Settings) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=International Apostolic Mission
SITE_URL=http://127.0.0.1:8001

# ── Tests only (optional — used by pytest, not the server) ───
IAM_API_BASE_URL=http://127.0.0.1:8001/api
IAM_TEST_ADMIN_EMAIL=
IAM_TEST_ADMIN_PASSWORD=
